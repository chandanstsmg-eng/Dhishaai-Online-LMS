# ─── DhishaAI LMS — server configuration ───────────────────────────────────────
# Copy this file to ".env" (in the same folder) and adjust the values:
#   Windows:  copy .env.example .env
#   Linux/mac: cp .env.example .env

# Port the server listens on. 80 = plain http://your-server (no port in the URL).
# On Linux, port 80 needs root (sudo). Use 3000/8080 for local development.
PORT=80

# Secret used to sign login tokens. CHANGE THIS to a long random string in production.
# Anyone who knows it can forge admin logins.
JWT_SECRET=change-this-to-a-long-random-secret-string

# production | development
NODE_ENV=production

# ─── Database backend ──────────────────────────────────────────────────────────
# Leave DB_ENGINE unset (or "sqlite") to use the built-in SQLite file — zero setup.
# Set DB_ENGINE=mysql to use the company's MySQL / MariaDB server instead.
DB_ENGINE=sqlite

# --- Only needed when DB_ENGINE=mysql ---
# Either give ONE connection URL:
# MYSQL_URL=mysql://username:password@db-host:3306/dhishaai_lms
# --- or the individual pieces (leave MYSQL_URL blank if you use these): ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dhishaai
MYSQL_PASSWORD=
MYSQL_DATABASE=dhishaai_lms
# The database (MYSQL_DATABASE) must already exist and the user must have full
# rights on it. Tables are created automatically on first start.

# ─── AI features (AI Tutor + Playground + Career advice) — optional ────────────
# Pick the AI engine. Switching later is just this one line — no code changes.
#   openai     = ChatGPT / OpenAI   (default, cheap with gpt-4o-mini)
#   anthropic  = Claude / Anthropic
AI_PROVIDER=openai

# --- If AI_PROVIDER=openai (ChatGPT) ---
# Get a key at https://platform.openai.com/api-keys  (paid per use; gpt-4o-mini is very cheap)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- If AI_PROVIDER=anthropic (Claude) ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# The key stays on the server and is never exposed to students' browsers.
# If the chosen provider has no key set, the AI features show a friendly
# "not configured" message and the rest of the app works normally.
